# ============================================================
# WENBOT COPYTRADING — Environment Variables Template
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in ALL values below
#   3. NEVER commit .env to git — it contains secrets!
#   Generate encryption key: python -c "import secrets; print(secrets.token_hex(32))"
# ============================================================

# --- Telegram ---
TELEGRAM_TOKEN=your_telegram_bot_token_here
ADMIN_CHAT_ID=your_admin_chat_id_here

# --- Security ---
# AES-256 encryption key (64 hex chars) — generate with command above
ENCRYPTION_KEY=generate_a_new_key_see_instructions_above

# --- Database ---
DB_URL=postgresql+asyncpg://polybot:CHANGE_THIS_PASSWORD@db:5432/polybot
REDIS_URL=redis://redis:6379

# --- Blockchain ---
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_NEW_API_KEY
POLYGON_RPC_FALLBACKS=https://polygon-rpc.com,https://rpc-mainnet.matic.quiknode.pro

# --- Fees ---
FEES_WALLET=0xYourNewFeesWalletAddress
PLATFORM_FEE_RATE=0.01

# --- Monitoring ---
MONITOR_POLL_INTERVAL=15

# --- Bridge (optional) ---
LIFI_API_KEY=your_lifi_api_key
ACROSS_API_URL=https://across.to/api
BRIDGE_SLIPPAGE=0.005

# --- Fiat on-ramp (optional) ---
TRANSAK_API_KEY=your_transak_api_key

# --- Execution tuning ---
MAX_CONCURRENT_TRADES=20
COLLECT_FEES_ONCHAIN=false

# --- UI / Branding ---
WELCOME_BANNER_URL=
